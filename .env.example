# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=stock_news_db
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=pipeline_secret

# Kafka / Redpanda Configuration
KAFKA_BROKERS=redpanda:29092
SCHEMA_REGISTRY_URL=http://redpanda:8081
KAFKA_CONSUMER_GROUP=stock-news-processor
KAFKA_TOPIC=stock_news_events
KAFKA_AUTO_OFFSET_RESET=earliest

# Pinecone Vector Database Configuration
PINECONE_API_KEY=
PINECONE_INDEX_NAME=stock-news
PINECONE_DIMENSION=1536
PINECONE_METRIC=cosine

# OpenAI Embedding API
OPENAI_API_KEY=
OPENAI_MODEL=text-embedding-3-small
OPENAI_BATCH_SIZE=50
OPENAI_RATE_LIMIT_RPM=3000

# Ollama Local Embeddings (zero-cost mode)
USE_LOCAL_EMBEDDINGS=false
OLLAMA_API_URL=http://ollama:11434
OLLAMA_MODEL=aroxima/gte-qwen2-1.5b-instruct:q4_k_m

# Application Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development

# Stream Processor Configuration
BATCH_SIZE=100
BATCH_TIMEOUT_SECONDS=5
EMBEDDING_RETRY_MAX_ATTEMPTS=3
EMBEDDING_RETRY_BACKOFF_BASE=2
GRACEFUL_SHUTDOWN_TIMEOUT=30

# Monitoring / Metrics (optional)
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=false

# Debezium Configuration (auto-managed by docker-compose)
DEBEZIUM_DB_HOSTNAME=postgres
DEBEZIUM_DB_PORT=5432
DEBEZIUM_DB_USER=pipeline_user
DEBEZIUM_DB_PASSWORD=pipeline_secret
DEBEZIUM_DB_NAME=stock_news_db
