{
  "name": "stock-news-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "postgres",
    "database.port": 5432,
    "database.user": "pipeline_user",
    "database.password": "pipeline_secret",
    "database.dbname": "stock_news_db",
    "database.server.name": "stock-news-db",
    "database.sslmode": "disable",
    "plugin.name": "pgoutput",
    "publication.name": "stock_news_publication",
    "slot.name": "stock_news_slot",
    "publication.autocreate.mode": "all_tables",
    "table.include.list": "public.stock_news",
    "tables.path": "/mnt/shared/tables",
    "logical.decoding.work.mem": 64000,
    "max.batch.size": 2048,
    "poll.interval.ms": 1000,
    "snapshot.mode": "always",
    "snapshot.isolation.mode": "read_committed",
    "snapshot.select.statement.overrides": "public.stock_news:SELECT * FROM stock_news WHERE deleted_at IS NULL ORDER BY id",
    "transforms": "route,unwrap",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "([^.]+)\\.([^.]+)\\.([^.]+)",
    "transforms.route.replacement": "${3}",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": false,
    "transforms.unwrap.delete.handling.mode": "rewrite",
    "transforms.unwrap.add.fields": "op,table,lsn,source.ts_ms",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://redpanda:8081",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": false,
    "key.schema.path": "/mnt/shared/keys/stock_news-key.json",
    "decimal.handling.mode": "double",
    "time.precision.mode": "adaptive_time_microseconds",
    "interval.handling.mode": "numeric",
    "include.unchanged.fields": false,
    "include.original.defaults": true,
    "internal.schema.pattern": "^(xmin|xmax|xid|cmax|cmin|tableoid)$",
    "retriable.restart.connector.wait.ms": 10000,
    "errors.log.enable": true,
    "errors.log.include.messages": true,
    "errors.deadletterqueue.enable": true,
    "errors.deadletterqueue.topic.name": "stock-news-errors-dlq",
    "errors.deadletterqueue.context.headers.enable": true,
    "tasks.max": 1,
    "name": "stock-news-connector",
    "database.history.kafka.bootstrap.servers": "redpanda:29092",
    "database.history.kafka.topic": "stock-news-db-history",
    "database.history.kafka.recovery.poll.interval.ms": 5000,
    "database.history.consumer.group.id": "stock-news-db-history-consumer",
    "topic.prefix": "stock_news",
    "topic.creation.enable": true,
    "topic.creation.default.replication.factor": 1,
    "topic.creation.default.partitions": 3,
    "topic.creation.default.retention.ms": 604800000,
    "topic.creation.default.retention.bytes": -1,
    "topic.creation.default.segment.ms": 86400000,
    "topic.creation.default.segment.bytes": 1073741824,
    "topic.creation.default.cleanup.policy": "delete",
    "topic.creation.default.compression.type": "snappy",
    "topic.creation.default.min.insync.replicas": 1,
    "topic.creation.default.flush.messages": 10000,
    "topic.creation.default.flush.ms": 1000
  }
}
